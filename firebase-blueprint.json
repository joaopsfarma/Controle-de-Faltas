{
  "entities": {
    "ShortageReport": {
      "title": "ShortageReport",
      "description": "A report of a shortage for a specific item.",
      "type": "object",
      "properties": {
        "itemId": {
          "type": "string",
          "description": "CSV Item Code"
        },
        "itemName": {
          "type": "string",
          "description": "Item description"
        },
        "reportedQuantity": {
          "type": "number",
          "description": "Quantity reported as missing"
        },
        "reportedAt": {
          "type": "string",
          "format": "date-time"
        },
        "userId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "resolved"]
        },
        "notes": {
          "type": "string"
        },
        "actionTaken": {
          "type": "string"
        }
      },
      "required": ["itemId", "itemName", "reportedQuantity", "reportedAt", "userId", "status"]
    },
    "CatalogItem": {
      "title": "CatalogItem",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "status": { "type": "string" },
        "isMissing": { "type": "boolean" },
        "quantityTotal": { "type": "number" },
        "quantityPending": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["itemId", "itemName", "status", "isMissing", "quantityTotal", "quantityPending", "updatedAt"]
    }
  },
  "firestore": {
    "/shortages/{shortageId}": {
      "schema": {
        "$ref": "#/entities/ShortageReport"
      },
      "description": "Detailed shortage reports based on CSV items."
    },
    "/catalog/{itemId}": {
      "schema": {
        "$ref": "#/entities/CatalogItem"
      },
      "description": "Catalog of items loaded from CSV."
    }
  }
}
