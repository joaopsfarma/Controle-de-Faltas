rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // The prompt says "strictly mandate that the user is verified using request.auth.token.email_verified == true" for standard writes, but now the user requested anonymous mode.
    function isSignedIn() { return request.auth != null; }
    function isRegistered() { return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous'; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'joaopsfarma@gmail.com'; }
    
    // Validation Blueprints
    function isValidShortageReport(data) {
      return data.itemId is string && data.itemId.size() > 0 && data.itemId.size() <= 100
        && data.itemName is string && data.itemName.size() > 0 && data.itemName.size() <= 500
        && data.reportedQuantity is number && data.reportedQuantity > 0
        && data.userId == request.auth.uid
        && data.status in ['pending', 'resolved']
        && (!data.keys().hasAny(['notes']) || (data.notes is string && data.notes.size() <= 1000))
        && (!data.keys().hasAny(['actionTaken']) || (data.actionTaken is string && data.actionTaken.size() <= 2000));
    }
    
    function isValidCatalogItem(data) {
      return data.itemId is string && data.itemId.size() > 0 && data.itemId.size() <= 100
        && data.itemName is string && data.itemName.size() > 0 && data.itemName.size() <= 500
        && data.status is string && data.status.size() <= 100
        && data.isMissing is bool
        && data.quantityTotal is number && data.quantityTotal >= 0
        && data.quantityPending is number && data.quantityPending >= 0;
    }

    match /catalog/{itemId} {
      allow get: if isSignedIn() && isValidId(itemId);
      allow list: if isSignedIn() && resource.data.status == 'Ativo';
      
      allow create: if isAdmin()
        && isValidId(itemId)
        && incoming().keys().hasAll(['itemId', 'itemName', 'status', 'isMissing', 'quantityTotal', 'quantityPending', 'updatedAt'])
        && incoming().keys().size() == 7
        && isValidCatalogItem(incoming())
        && incoming().updatedAt == request.time;
        
      allow update: if isAdmin()
        && isValidId(itemId)
        && isValidCatalogItem(incoming())
        && incoming().itemId == existing().itemId // immutable
        && incoming().updatedAt == request.time
        && (
            incoming().diff(existing()).affectedKeys().hasOnly(['itemName', 'status', 'isMissing', 'quantityTotal', 'quantityPending', 'updatedAt'])
        );
    }

    match /shortages/{shortageId} {
      allow get: if isSignedIn() && isValidId(shortageId) && (existing().userId == request.auth.uid || isRegistered());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isRegistered());
      
      allow create: if isSignedIn() 
        && isValidId(shortageId)
        && incoming().keys().hasAll(['itemId', 'itemName', 'reportedQuantity', 'reportedAt', 'userId', 'status'])
        && incoming().keys().size() <= 7
        && isValidShortageReport(incoming())
        && incoming().reportedAt == request.time;
        
      allow update: if isSignedIn() 
        && isValidId(shortageId)
        && (existing().userId == request.auth.uid || isRegistered())
        && isValidShortageReport(incoming()) // validates shape
        && incoming().itemId == existing().itemId // immutable
        && incoming().itemName == existing().itemName // immutable
        && incoming().userId == existing().userId // immutable
        && incoming().reportedAt == existing().reportedAt // immutable
        && (
            (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes', 'actionTaken']))
        )
        && (incoming().status == 'resolved' ? isRegistered() : true);
        
      allow delete: if isSignedIn() 
        && isValidId(shortageId) 
        && existing().userId == request.auth.uid;
    }
  }
}
