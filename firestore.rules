rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // We only use isSignedIn since this is an internal tool, maybe no email_verified check
    // Wait, the prompt says "strictly mandate that the user is verified using request.auth.token.email_verified == true"
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    
    // Validation Blueprints
    function isValidShortageReport(data) {
      return data.itemId is string && data.itemId.size() > 0 && data.itemId.size() <= 100
        && data.itemName is string && data.itemName.size() > 0 && data.itemName.size() <= 500
        && data.reportedQuantity is number && data.reportedQuantity > 0
        && data.userId == request.auth.uid
        && data.status in ['pending', 'resolved']
        && (!data.keys().hasAny(['notes']) || (data.notes is string && data.notes.size() <= 1000));
    }

    match /shortages/{shortageId} {
      allow get: if isSignedIn() && isValidId(shortageId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(shortageId)
        && incoming().keys().hasAll(['itemId', 'itemName', 'reportedQuantity', 'reportedAt', 'userId', 'status'])
        && incoming().keys().size() <= 7
        && isValidShortageReport(incoming())
        && incoming().reportedAt == request.time;
        
      allow update: if isSignedIn() 
        && isValidId(shortageId)
        && existing().userId == request.auth.uid
        && isValidShortageReport(incoming()) // validates shape
        && incoming().itemId == existing().itemId // immutable
        && incoming().itemName == existing().itemName // immutable
        && incoming().userId == existing().userId // immutable
        && incoming().reportedAt == existing().reportedAt // immutable
        && (
            (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes']))
        );
        
      allow delete: if isSignedIn() 
        && isValidId(shortageId) 
        && existing().userId == request.auth.uid;
    }
  }
}
